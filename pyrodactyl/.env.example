TZ=UTC

# Panel domain and app config
PANEL_HOST=ptero.example.com
APP_URL=https://ptero.example.com
APP_TIMEZONE=UTC
APP_SERVICE_AUTHOR=noreply@example.com
APP_ENV=production
APP_ENVIRONMENT_ONLY=false

# Panel DB (MariaDB)
MYSQL_PASSWORD=pyrodactyl
MYSQL_ROOT_PASSWORD=pyrodactyl
MYSQL_DATABASE=panel
MYSQL_USER=pterodactyl
DB_CONNECTION=mariadb
DB_HOST=database
DB_PORT=3306
DB_USERNAME=pterodactyl
DB_PASSWORD=pyrodactyl

# Panel cache/mail/misc
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_DRIVER=redis
REDIS_HOST=cache
MAIL_FROM=noreply@example.com
MAIL_DRIVER=smtp
MAIL_HOST=mail
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=true
HASHIDS_LENGTH=8

# Elytra API through proxy
ELYTRA_HOST=elytra.example.com
ELYTRA_PANEL_LOCATION=https://ptero.example.com
ELYTRA_TOKEN_ID=pyrodactyl
ELYTRA_TOKEN=pyrodactyl
ELYTRA_DEBUG=false
ELYTRA_UID=988
ELYTRA_GID=988
ELYTRA_DOCKER_TMPFS_SIZE=100
ELYTRA_SYSTEM_BACKUPS_RUSTIC_LOCAL_ENABLED=false
